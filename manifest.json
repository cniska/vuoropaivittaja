{
  "manifest_version": 3,
  "name": "Auto Clicker",
  "version": "1.0.0",
  "description": "Clicks configured buttons on matching pages at custom intervals.",
  "minimum_chrome_version": "120",
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "shared.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Auto Clicker",
    "default_popup": "popup.html"
  }
}
